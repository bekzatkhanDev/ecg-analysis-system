# ECG Analysis System Environment Configuration
# Copy this file to .env and update with your own values

# Application Settings
APP_NAME="ECG Analysis API"
DEBUG=false

# JWT Authentication Settings
# IMPORTANT: Change this to a strong, random secret key in production!
SECRET_KEY="your-super-secret-jwt-key-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Settings
DATABASE_URL="sqlite:///./ecg_analysis.db"

# ML Model Settings
MODEL_WEIGHTS_PATH="best_model_500hz.pth"
MODEL_NUM_CLASSES=5
MODEL_SEQ_LEN=5000
MODEL_N_LEADS=12

# Security Notes:
# 1. Never commit .env files to version control
# 2. Use a strong, randomly generated SECRET_KEY in production
# 3. Consider using environment-specific configuration
# 4. Rotate JWT secrets periodically in production